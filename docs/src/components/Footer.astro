---
import Default from '@astrojs/starlight/components/Footer.astro';
const base = import.meta.env.BASE_URL;
---

<Default><slot /></Default>

<footer class="seqera-footer">
  <div class="seqera-footer-content">
    <span>Developed for the community by <a href="https://seqera.io" target="_blank" rel="noopener noreferrer">Seqera</a> &bull; <a href="https://github.com/seqeralabs/RustQC">GitHub</a></span>
    <a href="https://seqera.io" target="_blank" rel="noopener noreferrer" class="seqera-logo">
      <img class="only-light" src={`${base}seqera-logo.svg`} alt="Seqera" />
      <img class="only-dark" src={`${base}seqera-logo-dark.svg`} alt="Seqera" />
    </a>
  </div>
</footer>

<style>
  .seqera-footer {
    padding: 1.5rem 0;
    border-top: 1px solid var(--sl-color-gray-5);
    margin-top: 1.5rem;
  }
  .seqera-footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
  }
  .seqera-footer-content span a {
    color: inherit;
    text-decoration: none;
  }
  .seqera-footer-content span a:hover {
    text-decoration: underline;
  }
  .seqera-footer-content a.seqera-logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }
  .seqera-footer-content img {
    height: 4rem;
    width: auto;
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }
  .seqera-footer-content a:hover img {
    opacity: 1;
  }
</style>
